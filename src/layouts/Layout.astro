---
import '../styles/global.css'

const {pathname} = Astro.url;
const currentPath = decodeURIComponent(pathname).replace(/\/$/, "") || "/";
const isHome = currentPath === "/";

const {
    title = "Cimetier - L'Atrie d'Itsuki Kigoshi",
    description = "木越 斎（きごし いつき、2004年9月25日-）は, 国際基督教大学で数学/地球科学を専攻する大学生です.",
    image
} = Astro.props;
---
<html lang="ja">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{title}</title>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:image" content={image}/>
    <link rel="icon" href="/favicon.ico"/>
</head>
<body class="min-h-dvh flex flex-col w-full justify-between">
<header class="w-full">
    {!isHome && <h1 class="text-3xl text-center font-bold pt-5 pb-4">{title}</h1>}
</header>
<slot/>
<footer class="w-full pb-6 flex flex-col items-center">
    {isHome ? (
            <div class="flex items-baseline justify-center gap-3 text-sm opacity-60">
                <a href="/legal" class="underline">特定商取引法</a>
                <span class="opacity-40">/</span>
                <a href="/itsukikigoshi.asc" class="underline">PGP Key</a> (Fingerprint: 5FEF A11E 52F0 AF96 960E  46B8 F555 5D33 934B 62B8)
            </div>
    ) : (
    <div class="flex items-baseline justify-center gap-3 text-sm opacity-60">
        <a href="/" class="underline">Home</a>
    </div>
    )
    }
</footer>
</body>
</html>