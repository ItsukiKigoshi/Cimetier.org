---
import "../styles/global.css";
import { Icon } from "astro-icon/components";

const { pathname } = Astro.url;
const currentPath = decodeURIComponent(pathname).replace(/\/$/, "") || "/";
const isHome = currentPath === "/";

const {
  title = '木越 斎 / Itsuki "Cimetier" Kigoshi',
  description = '木越 斎（きごし いつき、2004年9月25日-）は, 国際基督教大学で統計学を専攻する大学生です. Itsuki "Cimetier" Kigoshi is a unversity student studying statistics at ICU.',
  image = "https://cimetier.org/images/og-image.png",
} = Astro.props;
---
<html lang="ja">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{title}</title>
    <meta name="description" content={description}/>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:image" content={image}/>
    <link rel="icon" href="/favicon.ico"/>
</head>
<body class="min-h-dvh flex flex-col w-full justify-between">
<header class="w-full pt-5 pb-4">
    {isHome && (
    <section class="flex items-center justify-center opacity-80 gap-1.5 py-0.5">
        <Icon name="mdi:map-marker-outline" class="w-3 h-3" />
        <p class=" text-xs text-center">Tokyo, Japan</p>
    </section>
    <section class="flex items-center justify-center opacity-60 gap-1.5 py-0.5">
        <Icon name="mdi:chevron-right" class="w-3 h-3" />
        <p class="text-xs text-center">
            <a href="https://www.enzanso.co.jp/hutte-ooyari" target="_blank" rel="noopener noreferrer" class="underline">Hutte Ooyari, Nagano, Japan</a> (Jun-Oct, 2026)</p>
    </section>
    )}
</header>
<slot/>
<footer class="w-full pb-6 flex flex-col items-center">
    {isHome ? (
    <nav class="flex flex-col items-center gap-2 text-[12px] opacity-60">
        <button class="flex items-center gap-3">
            <a href="https://docs.cimetier.org/" class="underline">Docs</a>
            <span class="opacity-40">/</span>
            <a href="/legal" class="underline">Legal</a>
            <span class="opacity-40">/</span>
            <a href="/itsukikigoshi.asc" class="inline-flex items-end gap-1 underline group">
                GPG Key
                <Icon name="mdi:tray-arrow-down" class="w-4 h-4" />
            </a>
        </button>
        <button class="flex items-center gap-1.5 px-2 py-1">
            <Icon name="mdi:fingerprint" class="w-3 h-3" />
            <code class="font-mono text-[10px] select-all">5FEF A11E 52F0 AF96 960E  46B8 F555 5D33 934B 62B8</code>
        </button>
    </nav>
    ) : (
    <a href="/" class="inline-flex items-center gap-1 opacity-60 underline font-medium group">
        <Icon name="mdi:home" class="w-4 h-4" />
        Home
    </a>
    )
    }
</footer>
</body>
</html>
