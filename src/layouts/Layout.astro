---
import "../styles/global.css";
import { Icon } from "astro-icon/components";

const { pathname } = Astro.url;
const currentPath = decodeURIComponent(pathname).replace(/\/$/, "") || "/";
const isHome = currentPath === "/";

const {
	title = "Cimetier - L'Atrie d'Itsuki Kigoshi",
	description = "木越 斎（きごし いつき、2004年9月25日-）は, 国際基督教大学で数学/地球科学を専攻する大学生です.",
	image,
} = Astro.props;
---
<html lang="ja">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{title}</title>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:image" content={image}/>
    <link rel="icon" href="/favicon.ico"/>
</head>
<body class="min-h-dvh flex flex-col w-full justify-between">
<header class="w-full">
    {!isHome && <h1 class="text-3xl text-center font-bold pt-5 pb-4">{title}</h1>}
</header>
<slot/>
<footer class="w-full pb-6 flex flex-col items-center">
    {isHome ? (
    <nav class="flex flex-col items-center gap-2 text-[12px] opacity-60">
        <div class="flex items-center gap-3">
            <a href="/legal" class="underline">特定商取引法</a>
            <span class="opacity-40">/</span>
            <a href="/itsukikigoshi.asc" class="inline-flex items-end gap-1 underline font-medium group">
                GPG Key
                <Icon name="mdi:tray-arrow-down" class="w-4 h-4" />
            </a>
        </div>
        <div class="flex items-center gap-1.5 px-2 py-1 rounded">
            <Icon name="mdi:fingerprint" class="w-3 h-3" />
            <code class="font-mono text-[10px] select-all">359D 137D B901 C91B CDF9  8E60 E089 F042 AC48 2230</code>
        </div>
    </nav>
    ) : (
    <a href="/" class="inline-flex items-center gap-1 opacity-60 underline font-medium group">
        <Icon name="mdi:home" class="w-4 h-4" />
        Home
    </a>
    )
    }
</footer>
</body>
</html>